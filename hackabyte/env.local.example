# MongoDB Connection String - Replace with your own MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hackabyte?retryWrites=true&w=majority

# NextAuth.js Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here_at_least_32_chars

# Gmail Email Configuration
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password

# Note: To start using this file:
# 1. Rename this file to .env.local
# 2. Replace placeholder values with your actual configuration
# 3. Make sure not to commit your .env.local file to version control
